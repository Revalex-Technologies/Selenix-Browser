{
  "name": "selenix",
  "version": "3.0.0",
  "packageManager": "yarn@4.13.0",
  "sideEffects": false,
  "description": "Extensible, fast and innovative web browser with material UI built from a legally licensed version of Wexond.",
  "keywords": [
    "web-browser",
    "material",
    "electron",
    "react",
    "mobx",
    "styled-components"
  ],
  "homepage": "https://github.com/Revalex-Technologies/Selenix-Browser#readme",
  "main": "build/main.bundle.js",
  "author": "Revalex Technologies <revalextechnologies@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Revalex-Technologies/Selenix-Browser.git"
  },
  "bugs": {
    "url": "https://github.com/Revalex-Technologies/Selenix-Browser/issues"
  },
  "scripts": {
    "dev-renderer": "cross-env DEV=1 webpack serve --config webpack.config.renderer.js",
    "dev-webpack": "cross-env DEV=1 webpack",
    "build-renderer": "cross-env webpack --config webpack.config.renderer.js",
    "dev": "cross-env START=1 npm run watch",
    "build": "rimraf build && concurrently \"npm run build-renderer\" \"cross-env webpack\"",
    "ci-build": "node scripts/ci-build.js",
    "start": "electron .",
    "watch": "concurrently \"npm run dev-renderer\" \"npm run dev-webpack\"",
    "compile-win32": "npm run build && electron-builder -w",
    "compile-darwin": "npm run build && electron-builder -m",
    "compile-linux": "npm run build && electron-builder -l",
    "lint": "eslint \"src/**/*.ts*\" \"src/**/*.tsx*\"",
    "lint-fix": "npm run lint -- --fix",
    "rebuild": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@emotion/is-prop-valid": "^1.4.0",
    "@eslint/js": "^10.0.1",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@types/animejs": "^3.1.13",
    "@types/chrome": "^0.1.40",
    "@types/crypto-js": "^4.2.2",
    "@types/jszip": "^3.4.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/rimraf": "^4.0.5",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "animejs": "^4.4.1",
    "awesome-node-loader": "^1.1.1",
    "babel-loader": "^10.1.1",
    "concurrently": "^9.2.1",
    "copy-webpack-plugin": "^14.0.0",
    "cross-env": "^10.1.0",
    "electron": "^41.5.0",
    "electron-builder": "26.8.1",
    "electron-updater": "6.8.3",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "file-type": "^22.0.1",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "html-webpack-plugin": "^5.6.7",
    "jszip": "^3.10.1",
    "mobx": "^6.15.0",
    "mobx-react-lite": "^4.1.1",
    "node-bookmarks-parser": "^2.0.0",
    "prettier": "^3.8.3",
    "pretty-bytes": "^7.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-is": "^19.2.5",
    "react-refresh": "^0.18.0",
    "react-windows-controls": "^1.1.1",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "styled-components": "^6.4.1",
    "stylis": "^4.4.0",
    "terser": "^5.46.2",
    "terser-webpack-plugin": "^5.5.0",
    "ts-loader": "^9.5.7",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "typescript-plugin-styled-components": "^3.0.0",
    "webpack": "^5.106.2",
    "webpack-bundle-analyzer": "^5.3.0",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3",
    "webpack-merge": "^6.0.1"
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.14.4",
    "@ghostery/adblocker-electron-preload": "^2.14.4",
    "electron-chrome-extensions": "^4.9.0",
    "electron-chrome-web-store": "^0.13.0",
    "electron-store": "^11.0.2"
  },
  "resolutions": {
    "@types/react": "18.2.74",
    "@types/react-dom": "18.2.25",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  }
}
